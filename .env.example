# ─── Application ────────────────────────────────────────────────
APP_ENV=development
APP_NAME="AI Agent Orchestrator"
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
BACKEND_CORS_ORIGINS=["*"]

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/agent_db
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/agent_db

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── LLM Providers ─────────────────────────────────────────────
GROQ_API_KEY=gsk_your-groq-api-key
GOOGLE_API_KEY=your-gemini-api-key

# ─── Email ───────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp                 # smtp | sendgrid
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME="AI Agent Orchestrator"
SMTP_FROM_EMAIL=your-email@gmail.com
SENDGRID_API_KEY=SG.your-sendgrid-key

# ─── File Upload ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf

# ─── Worker ──────────────────────────────────────────────────────
CELERY_CONCURRENCY=4
AGENT_TIMEOUT_SECONDS=120
